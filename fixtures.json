{
  "model": "olga.category",
  "pk": 1,
  "fields": {
    "name": "Футболки и поло",
    "description": "Классические и современные модели футболок и поло из натуральных тканей. Идеально подходят для повседневной носки, офиса и активного отдыха. В ассортименте представлены изделия из хлопка, полиэстера и смесовых тканей с добавлением эластана для комфортной посадки."
  }
},
{
  "model": "olga.category",
  "pk": 2,
  "fields": {
    "name": "Джинсы и брюки",
    "description": "Универсальные джинсы и брюки на любой случай: от классических моделей для офиса до удобных карго для активного отдыха. Используются качественные ткани с добавлением эластана для комфорта и долговечности."
  }
},
{
  "model": "olga.category",
  "pk": 3,
  "fields": {
    "name": "Верхняя одежда",
    "description": "Куртки, пуховики и парки для защиты от ветра, дождя и мороза. Используются натуральная кожа, мембранные ткани и качественные утеплители. Подходят для города, активного отдыха и путешествий."
  }
},
