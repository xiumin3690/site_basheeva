{
  "model": "olga.product",
  "pk": 1,
  "fields": {
    "name": "Футболка хлопковая базовая",
    "price": "1500.00",
    "category": 1,
    "quantity": 15,
    "description": "Состав: 100% хлопок (плотность 180 г/м²)\r\nКлассическая базовая футболка прямого кроя из натурального хлопка высокой плотности. Обеспечивает отличную воздухопроницаемость, не вызывает раздражения, подходит для чувствительной кожи. Усиленные швы и двойная прострочка по низу и воротнику гарантируют долговечность. Футболка не вытягивается после стирки, сохраняет форму и цвет.",
    "image": "products/футболка.jpg"
  }
},
{
  "model": "olga.product",
  "pk": 2,
  "fields": {
    "name": "Поло классическое",
    "price": "2490.00",
    "category": 1,
    "quantity": 10,
    "description": "Состав: 95% хлопок, 5% эластан (ткань пике)\r\nКлассическое поло из фактурного пике. Добавление эластана обеспечивает комфортную посадку по фигуре, не стесняя движений. Воротник на двух пуговицах с прорезями для закрепления. Отлично подходит для повседневной носки и офиса.",
    "image": "products/поло.jpg"
  }
},
{
  "model": "olga.product",
  "pk": 3,
  "fields": {
    "name": "Джинсы классические прямые",
    "price": "4990.00",
    "category": 2,
    "quantity": 20,
    "description": "Классические джинсы прямого кроя средней посадки из плотного денима. Подходят для повседневной носки и офиса с нестрогим дресс-кодом.",
    "image": "products/джн.jpg"
  }
},
{
  "model": "olga.product",
  "pk": 4,
  "fields": {
    "name": "Брюки прямого кроя со стрелками",
    "price": "3990.00",
    "category": 2,
    "quantity": 15,
    "description": "Брюки прямого кроя - эта модель не обтягивает ногу, но и не создает эффект мешковатости, образуя четкую вертикальную линию . Наличие защипов (стрелок) добавляет элегантности, позволяя носить их как с кедами и худи для повседневного образа, так и с рубашкой и лоферами для офиса или встречи",
    "image": "products/бр_5M3cqNy.jpg"
  }
},
{
  "model": "olga.product",
  "pk": 5,
  "fields": {
    "name": "Куртка кожаная",
    "price": "12990.00",
    "category": 3,
    "quantity": 10,
    "description": "Состав: Натуральная кожа \r\nМужская кожаная куртка из натуральной кожи. Толщина кожи 1,2 мм обеспечивает защиту от ветра и лёгкого дождя. Подкладка из натурального хлопка дышит и не создаёт парникового эффекта.",
    "image": "products/КУР.jpg"
  }
},
{
  "model": "olga.product",
  "pk": 6,
  "fields": {
    "name": "Джинсовая куртка",
    "price": "5990.00",
    "category": 3,
    "quantity": 15,
    "description": "Джинсовая куртка в актуальном оверсайз-силуэте. В 2026 году такая модель становится must-have гардероба благодаря универсальности и комфорту. Куртка не сковывает движений, отлично сочетается как с узкими джинсами, так и с трендовыми широкими брюками.",
    "image": "products/джк.jpg"
  }
},
